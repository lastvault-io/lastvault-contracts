{
  "name": "lastvault-contracts-fhe",
  "version": "1.0.0",
  "description": "LastVault Inheritance — FHE-encrypted DMS contract (Fhenix Buildathon)",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:arb-sepolia": "npx hardhat run scripts/encrypt-and-deploy.ts --network arbitrumSepolia",
    "deploy:sepolia": "npx hardhat run scripts/encrypt-and-deploy.ts --network sepolia",
    "deploy:base-sepolia": "npx hardhat run scripts/encrypt-and-deploy.ts --network baseSepolia",
    "verify:arb-sepolia": "npx hardhat verify --network arbitrumSepolia",
    "verify:sepolia": "npx hardhat verify --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^20.0.0",
    "dotenv": "^16.6.1",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/sdk": "^0.5.1",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "viem": "^2.47.6"
  }
}
